<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARX Drawing Checker — Civil 3D"
        Height="700" Width="1080" MinHeight="500" MinWidth="820"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False">
  <Grid Margin="10">
    <TabControl x:Name="MainTabs">

      <TabItem Header="Results">
        <Grid Margin="8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <Button x:Name="RunCheckBtn" Content="Re-run Check" Width="110" Margin="0,0,8,0"/>
            <Button x:Name="ExportCsvBtn" Content="Export CSV..." Width="110" Margin="0,0,8,0"/>
            <Button x:Name="ExportPdfBtn" Content="Export Annotated PDF..." Width="170" Margin="0,0,16,0"/>
            <TextBlock x:Name="SummaryText" VerticalAlignment="Center" FontWeight="Bold" Text=""/>
          </StackPanel>
          <DataGrid x:Name="ResultsGrid" Grid.Row="1" AutoGenerateColumns="True"
                    IsReadOnly="True" SelectionMode="Single" HeadersVisibility="Column"
                    GridLinesVisibility="Horizontal" CanUserAddRows="False"/>
          <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,8,0,0">
            <Button x:Name="ZoomBtn" Content="Zoom to Mistake" Width="130" Margin="0,0,8,0"/>
            <Button x:Name="AddWordBtn" Content="Add Word to Dictionary" Width="170" Margin="0,0,8,0"/>
            <TextBlock x:Name="ResultsHint" VerticalAlignment="Center" Foreground="Gray"
                       Text="Double-click a row (or select it and click Zoom) to jump to it in the drawing."/>
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="Rules">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <Grid Margin="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <GroupBox Header="Project information (matched against title block; blank = skip)"
                      Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Padding="8">
              <StackPanel>
                <TextBlock Text="Project name"/>
                <TextBox x:Name="ProjectNameBox" Margin="0,2,0,8"/>
                <TextBlock Text="Project number"/>
                <TextBox x:Name="ProjectNumberBox" Margin="0,2,0,8"/>
                <TextBlock Text="Client"/>
                <TextBox x:Name="ClientBox" Margin="0,2,0,0"/>
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Layout (sheet) name pattern — regex, blank = disabled"
                      Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Padding="8">
              <StackPanel>
                <TextBox x:Name="SheetNamePatternBox" Margin="0,2,0,8" FontFamily="Consolas"/>
                <TextBlock Foreground="Gray" TextWrapping="Wrap"
                           Text="Checked against every layout tab name. Use the pattern builder below and 'Apply to Layout Name Pattern'."/>
              </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,8" Padding="8"
                      Header="Rules — add, edit or remove checks (Pattern for titleBlock/revision; Find + Valid for formatting)">
              <StackPanel>
                <DataGrid x:Name="RulesGrid" Height="170" AutoGenerateColumns="True"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                  <Button x:Name="AddRuleBtn" Content="New Rule" Width="100" Margin="0,0,8,0"/>
                  <Button x:Name="DeleteRuleBtn" Content="Delete Selected Rule" Width="150" Margin="0,0,16,0"/>
                  <TextBlock VerticalAlignment="Center" Foreground="Gray"
                             Text="Category: titleBlock, revision or formatting. Severity: error or warn. Edit cells directly."/>
                </StackPanel>
              </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,8" Padding="8"
                      Header="Pattern builder — type an example and its variable part; no regex needed">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,4">
                  <TextBlock Text="Example value (e.g. AA-001)"/>
                  <TextBox x:Name="ExampleBox" Margin="0,2,0,0" FontFamily="Consolas"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,4">
                  <TextBlock Text="Variable part(s), comma separated (e.g. 001)"/>
                  <TextBox x:Name="VariablePartsBox" Margin="0,2,0,0" FontFamily="Consolas"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,4">
                  <TextBlock Text="Generated pattern"/>
                  <TextBox x:Name="GeneratedPatternBox" Margin="0,2,0,0" FontFamily="Consolas" IsReadOnly="True"/>
                </StackPanel>
                <Button x:Name="GeneratePatternBtn" Grid.Row="0" Grid.Column="3" Content="Generate"
                        Width="90" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,4,8,0">
                  <TextBlock Text="Try a value against the pattern"/>
                  <TextBox x:Name="TestValueBox" Margin="0,2,0,0" FontFamily="Consolas"/>
                </StackPanel>
                <Button x:Name="TestPatternBtn" Grid.Row="1" Grid.Column="1" Content="Test"
                        Width="90" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                <TextBlock x:Name="TestResultText" Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                           VerticalAlignment="Bottom" Margin="0,0,0,4" FontWeight="Bold" Text=""/>
                <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.ColumnSpan="4" Margin="0,6,0,0">
                  <Button x:Name="ApplyPatternBtn" Content="Apply to Selected Rule" Width="160" Margin="0,0,8,0"/>
                  <Button x:Name="ApplySheetNameBtn" Content="Apply to Layout Name Pattern" Width="190" Margin="0,0,8,0"/>
                  <TextBlock VerticalAlignment="Center" Foreground="Gray"
                             Text="Example AA-001 with variable 001 gives: AA plus a dash plus any 3 digits."/>
                </StackPanel>
              </Grid>
            </GroupBox>

            <GroupBox Header="Custom dictionary (words the spell checker accepts; one per line)"
                      Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,8" Padding="8">
              <TextBox x:Name="CustomWordsBox" Height="90" AcceptsReturn="True"
                       VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
            </GroupBox>

            <StackPanel Orientation="Horizontal" Grid.Row="4" Grid.ColumnSpan="2" Margin="0,4,0,8">
              <Button x:Name="SaveRulesBtn" Content="Save Rules and Re-run" Width="170" Margin="0,0,8,0"/>
              <Button x:Name="ReloadRulesBtn" Content="Discard Changes" Width="130" Margin="0,0,16,0"/>
              <TextBlock x:Name="RulesPathText" VerticalAlignment="Center" Foreground="Gray"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Grid.Row="5" Grid.ColumnSpan="2" Margin="0,0,0,0">
              <Button x:Name="ImportRulesBtn" Content="Import Rules..." Width="120" Margin="0,0,8,0"/>
              <Button x:Name="ExportRulesBtn" Content="Export Rules..." Width="120" Margin="0,0,16,0"/>
              <Button x:Name="ImportDictBtn" Content="Import Dictionary..." Width="140" Margin="0,0,8,0"/>
              <Button x:Name="ExportDictBtn" Content="Export Dictionary..." Width="140" Margin="0,0,16,0"/>
              <TextBlock VerticalAlignment="Center" Foreground="Gray"
                         Text="Rules files are shared with the web and Revit checkers."/>
            </StackPanel>
          </Grid>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Find &amp; Replace">
        <Grid Margin="8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Find:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="FindBox" Grid.Column="1" Margin="0,0,12,0" VerticalAlignment="Center"/>
            <TextBlock Text="Replace with:" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="ReplaceBox" Grid.Column="3" Margin="0,0,12,0" VerticalAlignment="Center"/>
            <CheckBox x:Name="MatchCaseCheck" Grid.Column="4" Content="Match case" VerticalAlignment="Center"/>
          </Grid>
          <DataGrid x:Name="FindGrid" Grid.Row="1" AutoGenerateColumns="True"
                    IsReadOnly="True" SelectionMode="Single" HeadersVisibility="Column"
                    GridLinesVisibility="Horizontal" CanUserAddRows="False"/>
          <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,8,0,0">
            <Button x:Name="FindAllBtn" Content="Find All" Width="100" Margin="0,0,8,0"/>
            <Button x:Name="ReplaceAllBtn" Content="Replace All" Width="110" Margin="0,0,8,0"/>
            <Button x:Name="ZoomMatchBtn" Content="Zoom to Match" Width="130" Margin="0,0,16,0"/>
            <TextBlock x:Name="FindSummaryText" VerticalAlignment="Center" Foreground="Gray"
                       Text="Searches the TEXT/MTEXT objects on all layouts."/>
          </StackPanel>
        </Grid>
      </TabItem>

    </TabControl>
  </Grid>
</Window>
